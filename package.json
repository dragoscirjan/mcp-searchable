{
  "author": "Dragos Cirjan",
  "bin": {
    "mcp-searchable": "./dist/index.js"
  },
  "bugs": {
    "url": "https://github.com/dragoscirjan/mcp-searchable/issues"
  },
  "description": "Smart Web Extraction MCP Server",
  "devDependencies": {
    "@jscpd/badge-reporter": "^4.2.2",
    "@templ-project/eslint": "^1.3.0",
    "@templ-project/prettier": "^1.1.0",
    "@templ-project/vitest": "^0.3.2",
    "@types/axios": "^0.14.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^28.0.3",
    "@types/mozilla-readability": "^0.2.1",
    "@types/node": "^25.8.0",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.6",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "jscpd": "^4.2.2",
    "licensee": "^12.0.1",
    "lint-staged": "^17.0.5",
    "npm-run-all2": "^8.0.4",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.0",
    "typedoc": "0.28.19",
    "typedoc-plugin-markdown": "4.11.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [".npx-install", "dist"],
  "homepage": "https://github.com/dragoscirjan/mcp-searchable#readme",
  "keywords": [
    "bootstrap",
    "browser",
    "eslint",
    "esm",
    "import-maps",
    "node",
    "prettier",
    "template",
    "typescript",
    "vitest"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "name": "@dragoscirjan/mcp-searchable",
  "repository": {
    "type": "git",
    "url": "https://github.com/dragoscirjan/mcp-searchable.git"
  },
  "scripts": {
    "build": "run-s clean build:esm",
    "build:esm": "tsc -p tsconfig.json",
    "clean": "rimraf .nyc_output coverage dist site",
    "docs": "uv run mkdocs build --strict",
    "duplicate-check": "jscpd src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "license-check": "licensee --errors-only",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "prebuild": "run-s clean",
    "pretest": "run-s clean build",
    "start": "node dist/index.js",
    "start:debug": "node --inspect-brk dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate": "run-s format lint duplicate-check test",
    "postbuild": "chmod +x dist/index.js"
  },
  "sideEffects": false,
  "type": "module",
  "version": "1.0.2",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "axios": "^1.16.1",
    "better-sqlite3": "^12.10.0",
    "jsdom": "^29.1.1",
    "turndown": "^7.2.4"
  }
}
